name: NoFilter Bot 2

on:
  schedule:
    # Orari sfasati rispetto al Bot 1 (che gira a :07, :27, :47)
    # Questo gira a :15, :35, :55 — ogni 20 minuti, offset diverso
    - cron: '15,35,55 * * * *'
  workflow_dispatch:

jobs:
  run-bot:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 20

      - name: Install dependencies
        run: npm install

      - name: Run bot
        run: node bot2.js
        env:
          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
          SUPABASE_ANON_KEY: ${{ secrets.SUPABASE_ANON_KEY }}
